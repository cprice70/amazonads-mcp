{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.cprice70/amazonads-mcp",
  "description": "MCP server for Amazon Ads API - manage campaigns, keywords, bids, and performance reports",
  "repository": {
    "url": "https://github.com/cprice70/amazonads-mcp",
    "source": "github"
  },
  "version": "0.1.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "amazonads-mcp",
      "version": "0.1.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "AMAZON_ADS_CLIENT_ID",
          "description": "Amazon Ads API Client ID",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "AMAZON_ADS_CLIENT_SECRET",
          "description": "Amazon Ads API Client Secret",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "AMAZON_ADS_REFRESH_TOKEN",
          "description": "Amazon Ads API Refresh Token",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "AMAZON_ADS_REGION",
          "description": "Amazon Ads region (NA, EU, or FE)",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ]
}
