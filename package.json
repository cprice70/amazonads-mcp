{
  "name": "amazonads-mcp",
  "version": "0.2.0",
  "mcpName": "io.github.cprice70/amazonads-mcp",
  "description": "MCP server for Amazon Ads API integration",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "amazonads-mcp": "build/index.js"
  },
  "files": [
    "build",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cprice70/amazonads-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/cprice70/amazonads-mcp/issues"
  },
  "homepage": "https://github.com/cprice70/amazonads-mcp#readme",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
